{
  "name": "market-korea-crawl",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "crawl": "node crawl.js",
    "crawl:all": "node crawl.js --markets=joongna,bunjang,guheyo,mercari",
    "crawl:joongna": "node crawl.js --markets=joongna",
    "crawl:bunjang": "node crawl.js --markets=bunjang",
    "crawl:guheyo": "node crawl.js --markets=guheyo",
    "crawl:mercari": "node crawl.js --markets=mercari",
    "cleanup:data": "node scripts/cleanup-old-data.js --retention-days=14",
    "build": "node scripts/build-static.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "serve": "node --env-file-if-exists=.env server.js",
    "test": "node --test"
  },
  "dependencies": {
    "puppeteer": "^24.10.2"
  },
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}
